{
    // Use IntelliSense to learn about possible attributes.
    // Hover to view descriptions of existing attributes.
    // For more information, visit: https://go.microsoft.com/fwlink/?linkid=830387
    "version": "0.2.0",
    "configurations": [

        {
            "name": "Run Current File",
            "type": "debugpy",
            "request": "launch",
            "program": "${file}",
            "console": "integratedTerminal",
            "envFile": "${workspaceFolder}/agentcert/.env"
        },
        {
            "name": "Run fault bucketing (scripts)",
            "type": "debugpy",
            "request": "launch",
            "module": "fault_bucketing.scripts.fault_bucketing",
            "console": "integratedTerminal",
            "cwd": "${workspaceFolder}/agentcert",
            "envFile": "${workspaceFolder}/agentcert/.env",
            "args": [
                "--trace-file", "${workspaceFolder}/agentcert/data/langfuse_minio_traces/multi_fault/multi_fault_trace.json",
                "--output-dir", "${workspaceFolder}/agentcert/data/reports/buckets",
                "--batch-size", "10"
            ]
        }
    ]
}