# ─── AgentCert Build Paths Configuration ─────────────────────────────────────
# Copy this file and update each path to match your local environment.
# Pass it to build-all.sh via:
#   bash build-all.sh --llm 1 --env-file /path/to/.env --paths-file /path/to/build-paths.env

# Root of the AgentCert repo (this repo)
AGENTCERT_ROOT=/home/user/AgentCert

# Root of the app-charts repo (sock-shop Helm chart)
APP_CHARTS_ROOT=/home/user/app-charts

# Root of the agent-charts repo (install-agent Helm/Docker source)
AGENT_CHARTS_ROOT=/home/user/agent-charts

# Root of the flash-agent repo
FLASH_AGENT_ROOT=/home/user/flash-agent
