# ─── AgentCert Build Paths Configuration ─────────────────────────────────────
# Copy this file and update each path to match your local environment.
# Pass it to build-all.sh via:
#   bash build-all.sh --llm 1 --env-file /path/to/.env --paths-file /path/to/build-paths.env
#
# With --git flag, repos are auto-cloned/pulled from the URLs below before building:
#   bash build-all.sh --git --llm 1 --env-file /path/to/.env --paths-file /path/to/build-paths.env

# ── Local paths (where repos live / will be cloned to) ────────────────────────

# Root of the AgentCert repo (this repo)
AGENTCERT_ROOT=/home/user/AgentCert

# Root of the app-charts repo (sock-shop Helm chart)
APP_CHARTS_ROOT=/home/user/app-charts

# Root of the agent-charts repo (install-agent Helm/Docker source)
AGENT_CHARTS_ROOT=/home/user/agent-charts

# Root of the flash-agent repo
FLASH_AGENT_ROOT=/home/user/flash-agent

# ── Git repo URLs (used when --git flag is passed) ─────────────────────────────
# Leave blank to skip git sync for that repo.
AGENTCERT_GIT_URL=https://github.com/YOURUSERNAME/AgentCert.git
APP_CHARTS_GIT_URL=https://github.com/YOURUSERNAME/app-charts.git
AGENT_CHARTS_GIT_URL=https://github.com/YOURUSERNAME/agent-charts.git
FLASH_AGENT_GIT_URL=https://github.com/YOURUSERNAME/flash-agent.git

# Branch to use for all repos (default: main)
GIT_BRANCH=main
