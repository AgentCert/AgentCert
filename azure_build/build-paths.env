# ─── AgentCert Build Paths Configuration ─────────────────────────────────────
# Copy this file and update each path to match your local environment.
# Pass it to build-all.sh via:
#   bash build-all.sh --llm 1 --env-file /path/to/.env --paths-file /path/to/build-paths.env
#
# With --git flag, repos are auto-cloned/pulled from the URLs below before building:
#   bash build-all.sh --git --llm 1 --env-file /path/to/.env --paths-file /path/to/build-paths.env

# ── Local paths (where repos live / will be cloned to) ────────────────────────
# Using /tmp/agentcert-build/ so --git flag can clone without permission issues.
# These dirs are created automatically by build-all.sh when --git is used.

AGENTCERT_ROOT=/tmp/agentcert-build/AgentCert
APP_CHARTS_ROOT=/tmp/agentcert-build/app-charts
AGENT_CHARTS_ROOT=/tmp/agentcert-build/agent-charts
FLASH_AGENT_ROOT=/tmp/agentcert-build/flash-agent

# ── Git repo URLs (used when --git flag is passed) ─────────────────────────────
# Leave blank to skip git sync for that repo.
AGENTCERT_GIT_URL=https://github.com/AgentCert/AgentCert.git
APP_CHARTS_GIT_URL=https://github.com/AgentCert/app-charts.git
# AGENT_CHARTS_GIT_URL=https://github.com/AgentCert/agent-charts.git
AGENT_CHARTS_GIT_URL=https://github.com/sanjeevranjan-singh/agent-charts.git
# FLASH_AGENT_GIT_URL=https://github.com/AgentCert/flash-agent.git
FLASH_AGENT_GIT_URL=https://github.com/sanjeevranjan-singh/flash-agent.git
# URL for the Litmus Chaos Charts hub (used by the running GraphQL server as DEFAULT_HUB_GIT_URL)
CHAOS_CHARTS_GIT_URL=https://github.com/AgentCert/chaos-charts.git

# Branch to use for all repos (default: main)
GIT_BRANCH=main
