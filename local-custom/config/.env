# MongoDB Configuration
MONGODB_HOST=localhost
MONGODB_PORT=27017
MONGODB_DB_NAME=agentcert
MONGODB_USERNAME=admin
MONGODB_PASSWORD=1234
MONGODB_AUTH_SOURCE=admin
AUTH_PROXY_PORT=3000
GQL_PROXY_PORT=8080
TARGET_LOCALHOST=true

# MongoDB Connection String
MONGO_CONNECTION_STRING=mongodb://localhost:27017

# Auth Server Configuration
ADMIN_USERNAME=admin
ADMIN_PASSWORD=litmus
JWT_SECRET=litmus-portal@123
REST_PORT=3000
GRPC_PORT=3030

# Portal Configuration
PORTAL_ENDPOINT=http://100.104.32.37:8080
LITMUS_SVC_ENDPOINT=http://100.104.32.37:3000
SELF_AGENT=false
INFRA_SCOPE=cluster
INFRA_NAMESPACE=litmus
LITMUS_PORTAL_NAMESPACE=litmus
PORTAL_SCOPE=namespace
ALLOWED_ORIGINS=^(http://|https://|)((localhost|host\.docker\.internal|host\.minikube\.internal)|100\.104\.[0-9]+\.[0-9]+)(:[0-9]+|)$

# Image Configuration
SUBSCRIBER_IMAGE=agentcert/litmusportal-subscriber:3.0.0
EVENT_TRACKER_IMAGE=litmuschaos/litmusportal-event-tracker:3.0.0
CONTAINER_RUNTIME_EXECUTOR=k8sapi
ARGO_WORKFLOW_CONTROLLER_IMAGE=litmuschaos/workflow-controller:v3.3.1
ARGO_WORKFLOW_EXECUTOR_IMAGE=litmuschaos/argoexec:v3.3.1
CHAOS_CENTER_SCOPE=cluster

# Chaos Operator Images
CHAOS_OPERATOR_IMAGE=litmuschaos/chaos-operator:3.0.0
CHAOS_RUNNER_IMAGE=litmuschaos/chaos-runner:3.0.0
CHAOS_EXPORTER_IMAGE=litmuschaos/chaos-exporter:3.0.0
WORKFLOW_HELPER_IMAGE_VERSION=3.0.0
INSTALL_APPLICATION_IMAGE=agentcert/agentcert-install-app:ci-20260427042441
INSTALL_APPLICATION_IMAGE_PULL_POLICY=Always
INSTALL_AGENT_IMAGE=agentcert/agentcert-install-agent:latest
FLASH_AGENT_IMAGE=agentcert/agentcert-flash-agent:latest
AGENT_SIDECAR_IMAGE=agentcert/agent-sidecar:latest
INSTALL_AGENT_IMAGE_PULL_POLICY=Always

# Hub Configuration
VERSION=3.0.0
HUB_BRANCH_NAME=v2.0.x
DEFAULT_HUB_BRANCH_NAME=master
INFRA_DEPLOYMENTS=["app=chaos-exporter", "name=chaos-operator", "app=event-tracker","app=workflow-controller","app=kubernetes-mcp-server","app=prometheus-mcp-server"]
INFRA_COMPATIBLE_VERSIONS=["3.0.0"]

APP_HUB_SOURCE_MODE=custom
AGENT_HUB_SOURCE_MODE=custom
DEFAULT_APP_HUB_PATH=/tmp/default
DEFAULT_AGENT_HUB_PATH=/tmp/default
# Optional: set only if you want your own GitHub/GitLab repos
DEFAULT_APP_HUB_GIT_URL=https://github.com/agentcert/app-charts
DEFAULT_APP_HUB_BRANCH_NAME=main
DEFAULT_AGENT_HUB_GIT_URL=https://github.com/agentcert/agent-charts
DEFAULT_AGENT_HUB_BRANCH_NAME=main
DEFAULT_HUB_GIT_URL=https://github.com/agentcert/chaos-charts

# TLS Configuration
ENABLE_INTERNAL_TLS=false
SKIP_SSL_VERIFY=true

# Frontend Configuration
FRONTEND_PORT=2001
WEB_ENABLE_HTTPS=true

# Langfuse (optional) - Access via kubectl port-forward
# Run: kubectl port-forward -n langfuse svc/langfuse-web 3005:3000
# For local testing: LANGFUSE_HOST=
# For K8s pod-to-pod: LANGFUSE_HOST=
LANGFUSE_SECRET_KEY=sk-lf-5c1fa392-d793-4313-9bf7-d4162e7133a8
LANGFUSE_PUBLIC_KEY=pk-lf-ea294e97-3271-4a09-b8a2-d562f8e562c3
LANGFUSE_HOST=http://100.104.32.37:3001
LANGFUSE_ORG_ID=agentcert
LANGFUSE_PROJECT_ID=agentcert-project

# Agent Observability Contract
# OTLP endpoint = LANGFUSE_HOST/api/public/otel
# OTLP headers  = Authorization=Basic base64(LANGFUSE_PUBLIC_KEY:LANGFUSE_SECRET_KEY)
# These are also used by the GraphQL server (OTEL_EXPORTER_OTLP_ENDPOINT / _HEADERS) via sync_langfuse_env_from_dotenv.
AGENT_OTEL_EXPORTER_OTLP_ENDPOINT=http://100.104.32.37:3001/api/public/otel
AGENT_OTEL_EXPORTER_OTLP_HEADERS=Authorization=Basic cGstbGYtZWEyOTRlOTctMzI3MS00YTA5LWI4YTItZDU2MmY4ZTU2MmMzOnNrLWxmLTVjMWZhMzkyLWQ3OTMtNDMxMy05YmY3LWQ0MTYyZTcxMzNhOA==

# Blind Traces Mode
# yes = OTEL fault spans use F1/F2 aliases; no identifying fault attributes emitted
# no  = full fault details in OTEL spans (useful for local dev/debugging)
BLIND_TRACES=yes

# Azure OpenAI Configuration
# Get these from Azure Portal > Azure OpenAI > Keys and Endpoint
# Both AZURE_OPENAI_KEY and AZURE_OPENAI_API_KEY are supported; prefer AZURE_OPENAI_KEY
AZURE_OPENAI_KEY=
AZURE_OPENAI_ENDPOINT=https://aiarc-arc-resource.openai.azure.com
AZURE_OPENAI_DEPLOYMENT=gpt-4o-mini
#AZURE_OPENAI_DEPLOYMENT=
AZURE_OPENAI_API_VERSION=2025-01-01-preview

# Azure OpenAI Embeddings Deployment (Optional - for RAGAS evaluation)
# If deployed, set to your embedding deployment name
AZURE_OPENAI_EMBEDDING_DEPLOYMENT=
DB_SERVER=mongodb://localhost:27017

SERVER_ADDR=http://100.104.32.37:8080/query

LITELLM_PROXY_IMAGE=docker.io/litellm/litellm:v1.82.0-stable
LITELLM_PROFILE=azure
LITELLM_MASTER_KEY=sk-agentcert-2026

# Pre-cleanup wait step injected into Argo workflow just before cleanup-chaos-resources.
# Set to 0 for no wait (step still appears in workflow graph), or e.g. 300 for 5 minutes.
PRE_CLEANUP_WAIT_SECONDS=

# GraphQL Server Configuration
GQL_REST_PORT=8080
GQL_GRPC_PORT=8082
ENABLE_GQL_INTROSPECTION=true
LITMUS_AUTH_GRPC_ENDPOINT=localhost
LITMUS_AUTH_GRPC_PORT=3030
AUTH_PROXY_PORT=3000

# MCP Server Images
KUBERNETES_MCP_SERVER_IMAGE=quay.io/containers/kubernetes_mcp_server:latest
PROMETHEUS_MCP_SERVER_IMAGE=agentcert/prometheus-mcp-server:latest
PROMETHEUS_MCP_URL=http://prometheus.monitoring.svc.cluster.local:9090
K8S_MCP_URL=http://kubernetes-mcp-server.litmus.svc.cluster.local:8081/mcp
PROM_MCP_URL=http://prometheus-mcp-server.litmus.svc.cluster.local:9090/mcp
CHAOS_NAMESPACE=litmus
LITMUS_PROJECT_ID=admin-project

# OTEL / Langfuse tracing for GraphQL server
OTEL_EXPORTER_OTLP_ENDPOINT=http://100.104.32.37:3001/api/public/otel
OTEL_EXPORTER_OTLP_HEADERS=Authorization=Basic cGstbGYtZWEyOTRlOTctMzI3MS00YTA5LWI4YTItZDU2MmY4ZTU2MmMzOnNrLWxmLTVjMWZhMzkyLWQ3OTMtNDMxMy05YmY3LWQ0MTYyZTcxMzNhOA==

