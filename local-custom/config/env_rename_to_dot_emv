# Agent Observability Contract
# OTLP endpoint = LANGFUSE_HOST/api/public/otel
# OTLP headers  = Authorization=Basic base64(LANGFUSE_PUBLIC_KEY:LANGFUSE_SECRET_KEY)
# These are also used by the GraphQL server (OTEL_EXPORTER_OTLP_ENDPOINT / _HEADERS) via sync_langfuse_env_from_dotenv.
AGENT_OTEL_EXPORTER_OTLP_ENDPOINT=
AGENT_OTEL_EXPORTER_OTLP_HEADERS=

# Blind Traces Mode
# yes = OTEL fault spans use F1/F2 aliases; no identifying fault attributes emitted
# no  = full fault details in OTEL spans (useful for local dev/debugging)
BLIND_TRACES=yes

