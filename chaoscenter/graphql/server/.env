# Required environment variables for GraphQL server
VERSION=1.0.0
INFRA_DEPLOYMENTS={}
DB_SERVER=mongodb://localhost:27015,localhost:27016,localhost:27017/?replicaSet=rs0
DB_USER=
DB_PASSWORD=
SUBSCRIBER_IMAGE=agentcert/litmusportal-subscriber:3.0.0
EVENT_TRACKER_IMAGE=litmuschaos/litmusportal-event-tracker:latest
ARGO_WORKFLOW_CONTROLLER_IMAGE=litmuschaos/workflow-controller:latest
ARGO_WORKFLOW_EXECUTOR_IMAGE=litmuschaos/argoexec:latest
LITMUS_CHAOS_OPERATOR_IMAGE=litmuschaos/chaos-operator:latest
LITMUS_CHAOS_RUNNER_IMAGE=litmuschaos/chaos-runner:latest
LITMUS_CHAOS_EXPORTER_IMAGE=litmuschaos/chaos-exporter:latest
CONTAINER_RUNTIME_EXECUTOR=k8sapi
WORKFLOW_HELPER_IMAGE_VERSION=latest
CHAOS_CENTER_UI_ENDPOINT=https://localhost:8080
LITMUS_AUTH_GRPC_ENDPOINT=localhost
LITMUS_AUTH_GRPC_PORT=3031
REST_PORT=8080
GRPC_PORT=8000
INFRA_COMPATIBLE_VERSIONS=0.0.0
DEFAULT_HUB_GIT_URL=https://github.com/agentcert/chaos-charts
GIT_USERNAME=litmus
DEFAULT_HUB_BRANCH_NAME=master
CUSTOM_CHAOS_HUB_PATH=/tmp/
DEFAULT_CHAOS_HUB_PATH=/tmp/default/
ENABLE_GQL_INTROSPECTION=true
ENABLE_INTERNAL_TLS=false
ALLOWED_ORIGINS=.*
SKIP_SSL_VERIFY=true
JWT_SECRET=litmus-portal@123
